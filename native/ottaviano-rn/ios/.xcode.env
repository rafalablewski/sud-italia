# .xcode.env — committed default environment for the RN build script phases.
#
# The "Bundle React Native code and images" phase sources this (and the
# gitignored .xcode.env.local, if present) to locate node. Override locally by
# creating ios/.xcode.env.local with a different NODE_BINARY (e.g. an nvm path).

export NODE_BINARY=$(command -v node)
