<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    App Store / TestFlight distribution of a macOS app REQUIRES the App Sandbox
    (com.apple.security.app-sandbox) — App Store Connect rejects an un-sandboxed
    macOS upload. iOS apps don't need this; macOS does.

    network.client: OttavianoKDS talks to the production API over HTTPS
    (https://sud-italia.vercel.app/api/v1). Without this the sandbox blocks all
    outbound connections and every screen fails to load.
  -->
  <key>com.apple.security.app-sandbox</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
