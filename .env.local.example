# Stripe (optional — site works in demo mode without these)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin password (required in production)
ADMIN_PASSWORD=your-secure-password-here

# Session signing secret for admin + kitchen cookies (required in production; may match ADMIN_PASSWORD)
SESSION_SECRET=your-random-secret-here

# Kitchen staff: JSON map of location slug -> password (required for kitchen login)
# KITCHEN_PASSWORDS={"krakow":"generate-a-strong-secret","warszawa":"another-strong-secret"}

# Neon Postgres (required for persistent storage on Vercel)
# Get your connection string at https://console.neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require

# Live cart snapshots for kitchen board (off unless true in production; on in dev unless set to false)
# NEXT_PUBLIC_ENABLE_CART_PRESENCE=true

# Upstash Redis (optional — shared cart presence across Vercel instances; create at https://console.upstash.com)
# Also backs the distributed lock (m0_1) + rate limiter (m0_11). Required in production.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Vercel Cron auth (m1_12). Vercel sets this header automatically on cron
# invocations; you set the same string in the Vercel dashboard. Required for
# the scheduled jobs in vercel.json to authorize.
# CRON_SECRET=long-random-string

# Twilio SMS (m2_15). All three required to activate the provider; otherwise
# customer messaging is a no-op log line.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+48...

# Mailgun email (m2_15). All three required to activate. MAILGUN_REGION=eu
# routes through the EU endpoint for GDPR / Polish data residency.
# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.suditalia.pl
# MAILGUN_FROM=Sud Italia <hello@mg.suditalia.pl>
# MAILGUN_REGION=eu

# Aggregator integrations (m2_21). Flag-gated so the code can ship before
# real merchant relationships land. When ENABLE_AGGREGATORS=true, the
# webhook routes accept Wolt/Glovo traffic; when credentials below are
# set, requests are signature-verified against the real shared secrets,
# otherwise the mock providers accept everything (dev/staging only).
# ENABLE_AGGREGATORS=false
# WOLT_API_KEY=...
# WOLT_WEBHOOK_SECRET=...
# GLOVO_API_KEY=...
# GLOVO_WEBHOOK_SECRET=...

# Anthropic API (m4_1). Required for the ops agent at /admin/ai. When
# unset, the agent UI shows "not configured" and no Claude calls are
# made. Tool calls are still registered so the audit trail and
# preview-card flow work end-to-end in dev.
# ANTHROPIC_API_KEY=sk-ant-...

# AI daily spend cap (m4_5). Defaults to 100000 grosze (1000 PLN) when
# unset. The agent route returns 429 + a friendly message when the
# day's accumulated cost crosses this threshold.
# AI_DAILY_BUDGET_GROSZE=100000
