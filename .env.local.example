# Stripe (optional — site works in demo mode without these)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin password hash (preferred). Salted scrypt hash of the admin password.
# Generate with:  tsx scripts/hash-admin-password.ts   (then paste the scrypt$... line)
# When set, login verifies against this in constant time and ADMIN_PASSWORD is unused.
ADMIN_PASSWORD_HASH=

# Admin password — DEPRECATED plaintext fallback, used only when ADMIN_PASSWORD_HASH
# is unset. Set the hash above and remove this in production.
ADMIN_PASSWORD=your-secure-password-here

# Optional TOTP MFA for the SHARED owner session (no-email login). When set, the
# shared login also requires a 6-digit authenticator code. Generate with:
#   tsx scripts/generate-totp-secret.ts
# Per-user MFA (email logins) is enrolled in the UI at /admin/users.
# ADMIN_TOTP_SECRET=

# Session signing secret for admin + kitchen cookies (required in production; may match ADMIN_PASSWORD)
SESSION_SECRET=your-random-secret-here

# Kitchen staff: JSON map of location slug -> password (required for kitchen login)
# KITCHEN_PASSWORDS={"krakow":"generate-a-strong-secret","warszawa":"another-strong-secret"}

# WebAuthn (passkeys / hardware security keys like YubiKey). Optional — by
# default the rpID + origin are derived from the request host, which is correct
# for a normal Vercel deployment. Set these only when the app sits behind a
# proxy/custom domain where the forwarded host can't be trusted. rpID is the
# bare domain (no scheme/port); origin is the full URL the user is on. They MUST
# match the browser's address bar or the authenticator rejects the credential.
# WEBAUTHN_RP_ID=sudistia.com
# WEBAUTHN_ORIGIN=https://sudistia.com

# Neon Postgres (required for persistent storage on Vercel)
# Get your connection string at https://console.neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require

# Live cart snapshots for kitchen board (off unless true in production; on in dev unless set to false)
# NEXT_PUBLIC_ENABLE_CART_PRESENCE=true

# Upstash Redis (optional — shared cart presence across Vercel instances; create at https://console.upstash.com)
# Also backs the distributed lock (m0_1) + rate limiter (m0_11). Required in production.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Per-user ceiling on admin API calls (every withAdmin route). Default 300/min/user.
# ADMIN_RATE_LIMIT_PER_MIN=300

# Admin IP allowlist (optional). Comma-separated exact client IPs allowed to reach
# the admin surface; any other IP gets 403. Unset = open to all. Exact-match, no CIDR.
# ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.4

# Delivery address autocomplete (Appendix A). Optional — when set, /api/address/
# autocomplete uses Google Places; otherwise it falls back to free OSM Nominatim.
# ADDRESS_AUTOCOMPLETE_GOOGLE_KEY=
# (GOOGLE_MAPS_API_KEY is also accepted if you already have one.)

# Sentry error monitoring + alerting. When unset, all capture calls no-op (safe
# for local/dev). instrumentation.ts loads the server/edge init from this.
# Alert rules (>1% 5xx, lock-fallback) are documented in docs/runbooks/alerting.md.
# SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz

# Vercel Cron auth (m1_12). Vercel sets this header automatically on cron
# invocations; you set the same string in the Vercel dashboard. Required for
# the scheduled jobs in vercel.json to authorize.
# CRON_SECRET=long-random-string

# Nightly DB backup to S3 (Appendix A). All four required to activate; the
# cron self-skips when any are missing. Restore: docs/runbooks/backup-restore.md.
# BACKUP_S3_BUCKET=my-bucket
# BACKUP_S3_REGION=eu-central-1
# BACKUP_S3_ACCESS_KEY_ID=AKIA...
# BACKUP_S3_SECRET_ACCESS_KEY=...
# BACKUP_S3_PREFIX=backups/sud-italia          # optional
# BACKUP_S3_ENDPOINT=https://...               # optional, for R2/MinIO (path-style)

# Twilio SMS (m2_15). All three required to activate the provider; otherwise
# customer messaging is a no-op log line.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+48...

# Mailgun email (m2_15). All three required to activate. MAILGUN_REGION=eu
# routes through the EU endpoint for GDPR / Polish data residency.
# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.suditalia.pl
# MAILGUN_FROM=Sud Italia <hello@mg.suditalia.pl>
# MAILGUN_REGION=eu

# Aggregator integrations (m2_21). Flag-gated so the code can ship before
# real merchant relationships land. When ENABLE_AGGREGATORS=true, the
# webhook routes accept Wolt/Glovo traffic; when credentials below are
# set, requests are signature-verified against the real shared secrets,
# otherwise the mock providers accept everything (dev/staging only).
# ENABLE_AGGREGATORS=false
# WOLT_API_KEY=...
# WOLT_WEBHOOK_SECRET=...
# GLOVO_API_KEY=...
# GLOVO_WEBHOOK_SECRET=...

# Anthropic API (m4_1). Required for the ops agent at /admin/ai. When
# unset, the agent UI shows "not configured" and no Claude calls are
# made. Tool calls are still registered so the audit trail and
# preview-card flow work end-to-end in dev.
# ANTHROPIC_API_KEY=sk-ant-...

# AI daily spend cap (m4_5). Defaults to 100000 grosze (1000 PLN) when
# unset. The agent route returns 429 + a friendly message when the
# day's accumulated cost crosses this threshold.
# AI_DAILY_BUDGET_GROSZE=100000

# Web Push (m5_6). Generate once with `npx web-push generate-vapid-keys`,
# install `web-push` (npm), and uncomment the import in
# src/lib/push-notifications.ts. Until those land, the helper is a
# logging stub — subscriptions persist but no message is dispatched.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...
# VAPID_PRIVATE_KEY=...
