      "post": {
        "summary": "Create an order (customer app / guest) — server-priced, idempotent",
        "description": "Zero-friction: no auth required (guest supplies name+phone); a customer Bearer token supplies the phone instead. Pass an Idempotency-Key header to make retries safe. Created unpaid; payment is a later increment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "locationSlug": {
                    "type": "string"
                  },
                  "items": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "quantity": {
                          "type": "integer",
                          "exclusiveMinimum": 0,
                          "maximum": 9007199254740991
                        },
                        "notes": {
                          "type": "string",
                          "maxLength": 140
                        },
                        "selectedModifiers": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "groupId": {
                                "type": "string"
                              },
                              "optionId": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "groupId",
                              "optionId"
                            ],
                            "additionalProperties": false
                          }
                        }
                      },
                      "required": [
                        "id",
                        "quantity"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "fulfillmentType": {
                    "type": "string",
                    "enum": [
                      "takeout",
                      "delivery",
                      "dine-in"
                    ]
                  },
                  "customerName": {
                    "type": "string",
                    "minLength": 1
                  },
                  "customerPhone": {
                    "type": "string"
                  },
                  "slotId": {
                    "type": "string"
                  },
                  "slotDate": {
                    "type": "string"
                  },
                  "slotTime": {
                    "type": "string"
                  },
                  "immediate": {
                    "type": "boolean"
                  },
                  "tableNumber": {
                    "type": "string"
                  },
                  "deliveryAddress": {
                    "type": "string"
                  },
                  "partySize": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "tipAmount": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "appliedBundleId": {
                    "type": "string"
                  },
                  "channel": {
                    "type": "string",
                    "enum": [
                      "web",
                      "whatsapp",
                      "qr"
                    ]
                  }
                },
                "required": [
                  "locationSlug",
                  "items",
                  "fulfillmentType"
                ],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Existing order (idempotent replay)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Order"
                    },
                    "meta": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "201": {
            "description": "Created order",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Order"
                    },
                    "meta": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Error envelope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
